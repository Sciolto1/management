<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hr.management.mapper.FundTransactionMapper">

    <resultMap id="BaseResultMap" type="com.hr.management.entity.FundTransaction">
        <id column="id" property="id"/>
        <result column="fund_id" property="fundId"/>
        <result column="account_no" property="accountNo"/>
        <result column="name" property="name"/>
        <result column="trans_date" property="transDate"/>
        <result column="debit" property="debit"/>
        <result column="credit" property="credit"/>
        <result column="balance" property="balance"/>
        <result column="type" property="type"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByFundId" resultMap="BaseResultMap">
        SELECT * FROM fund_transaction WHERE fund_id = #{fundId} ORDER BY trans_date DESC
    </select>

    <select id="selectByDateRange" resultMap="BaseResultMap">
        SELECT * FROM fund_transaction 
        WHERE trans_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY trans_date DESC
    </select>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT * FROM fund_transaction WHERE type = #{type} ORDER BY trans_date DESC
    </select>

    <select id="getLatestBalance" resultType="java.math.BigDecimal">
        SELECT balance FROM fund_transaction 
        WHERE fund_id = #{fundId} 
        ORDER BY trans_date DESC, id DESC 
        LIMIT 1
    </select>

</mapper>
